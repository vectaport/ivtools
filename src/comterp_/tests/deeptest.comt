// src/comterp_/tests/deeptest.comt -- deep stress tests for list and attrlist
//
// coverage: slot 12 stress, deep structure
// funcs: list attrlist at size attrname attrval + - . for while if cond func global
// missing: none (stress only, not exhaustive API)
//
// Tests list and attrlist under:
//   - lengths > 256
//   - binary expressions 3-4 levels deep
//   - nested structures (list-in-attrlist, attrlist-in-list, list-in-list)
//   - control flow wrapping: for, while, if, cond, func
//   - round-trip integrity: build, mutate, enumerate, verify
//   - merge (+) and remove (-) at scale
//
// Run from inside comterp, comdraw, or drawserv:
//   run("src/comterp_/tests/deeptest.comt")

run("./testlib.comt")
ok=true

// =========================================================
// PART 1: Large lists (>256 elements)
// =========================================================

// --- test 1: build list of 300 ints via for loop ---
lst=list()
for(i=0 i<300 i++ lst=lst,i)
ok=ok&&(size(lst)==300)
ok=ok&&(at(lst 0)==0)
ok=ok&&(at(lst 299)==299)
print("1 list of 300 ints (expect size=300, first=0, last=299): %v %v %v\n" size(lst) at(lst 0) at(lst 299))
prev_ok=check_fail(:ok ok)

// --- test 2: enumerate 300-element list and verify sum ---
total=0
for(i=0 i<size(lst) i++ total=total+at(lst i))
ok=ok&&(total==299*300/2)
print("2 sum of 0..299 (expect 44850): %v\n" total)
prev_ok=check_fail(:ok ok)

// --- test 3: build list of 300 elements via while ---
lst2=list()
i=0
while(i<300 (lst2=lst2,i*2; i=i+1))
ok=ok&&(size(lst2)==300)
ok=ok&&(at(lst2 150)==300)
print("3 list of 300 even ints via while (expect size=300, at(150)=300): %v %v\n" size(lst2) at(lst2 150))
prev_ok=check_fail(:ok ok)

// --- test 4: list of 300 strings ---
slst=list()
for(i=0 i<300 i++ slst=slst,print(i :str))
ok=ok&&(size(slst)==300)
ok=ok&&(at(slst 0)=="0")
ok=ok&&(at(slst 255)=="255")
ok=ok&&(at(slst 299)=="299")
print("4 list of 300 strings (expect size=300, at(0)=\"0\", at(255)=\"255\"): %v %v %v\n\n" size(slst) at(slst 0) at(slst 255))
prev_ok=check_fail(:ok ok)

// --- test 5: list of 300 mixed types (int, float, string, bool, nil) ---
mlst=list()
for(i=0 i<300 i++
  if(i%5==0 :then mlst,i :else
    if(i%5==1 :then mlst,float(i)*1.1 :else
      if(i%5==2 :then mlst,print(i :str) :else
        cond(i%5==3 mlst,true mlst,nil)))));
ok=ok&&(size(mlst)==300)
ok=ok&&(type(at(mlst 0))==`IntType||type(at(mlst 0))==`DfintType)
ok=ok&&(type(at(mlst 1))==`FloatType||type(at(mlst 1))==`DoubleType)
ok=ok&&(type(at(mlst 2))==`StringType)
ok=ok&&(at(mlst 3)==true)
ok=ok&&(at(mlst 4)==nil)
print("5 mixed-type list of 300 (expect size=300, types int/float/str/bool/nil): %v\n\n" size(mlst))
prev_ok=check_fail(:ok ok)

// =========================================================
// PART 2: Large attrlists (>256 keys)
// =========================================================

// --- test 6: attrlist with 300 keys via dot assignment ---
al=attrlist()
for(i=0 i<300 i++ at(al i :set i*3))
// Note: at(:set) with integer index sets by position
// Use a list of attrlists instead to hit 300 named keys
al2=list()
for(i=0 i<300 i++ al2=al2,attrlist(:v i))
ok=ok&&(size(al2)==300)
ok=ok&&(at(al2 0).v==0)
ok=ok&&(at(al2 299).v==299)
print("6 list of 300 single-key attrlists (expect size=300, first.v=0, last.v=299): %v %v %v\n\n" size(al2) at(al2 0).v at(al2 299).v)
prev_ok=check_fail(:ok ok)

// --- test 7: enumerate list of attrlists, sum .v ---
total=0
for(i=0 i<size(al2) i++ total=total+at(al2 i).v)
ok=ok&&(total==299*300/2)
print("7 sum .v from list of 300 attrlists (expect 44850): %v\n\n" total)
prev_ok=check_fail(:ok ok)

// --- test 8: wide attrlist with 10 keys, deep values ---
wide=attrlist(:a 1 :b 2 :c 3 :d 4 :e 5 :f 6 :g 7 :h 8 :i 9 :j 10)
ok=ok&&(size(wide)==10)
ok=ok&&(wide.a+wide.b+wide.c+wide.d+wide.e+wide.f+wide.g+wide.h+wide.i+wide.j==55)
print("8 wide 10-key attrlist sum (expect 55): %v\n\n" (wide.a+wide.b+wide.c+wide.d+wide.e+wide.f+wide.g+wide.h+wide.i+wide.j))
prev_ok=check_fail(:ok ok)

// =========================================================
// PART 3: Deep nesting
// =========================================================

// --- test 9: list of lists 3 deep ---
outer=list()
for(i=0 i<10 i++
  mid=list();
  for(j=0 j<10 j++ mid,i*10+j);
  outer,mid)
ok=ok&&(size(outer)==10)
ok=ok&&(size(at(outer 0))==10)
ok=ok&&(at(at(outer 0) 0)==0)
ok=ok&&(at(at(outer 9) 9)==99)
print("9 10x10 nested list (expect outer=10, inner=10, [0][0]=0, [9][9]=99): %v %v %v %v\n\n" size(outer) size(at(outer 0)) at(at(outer 0) 0) at(at(outer 9) 9))
prev_ok=check_fail(:ok ok)

// --- test 10: list of lists 4 deep ---
d4=list()
for(i=0 i<4 i++
  l2=list();
  for(j=0 j<4 j++
    l3=list();
     for(k=0 k<4 k++
       l4=list();
        for(m=0 m<4 m++ l4=l4,i*64+j*16+k*4+m);
        l3=l3,l4);
     l2=l2,l3);
  d4=d4,l2)
ok=ok&&(size(d4)==4)
ok=ok&&(at(at(at(at(d4 0) 0) 0) 0)==0)
ok=ok&&(at(at(at(at(d4 3) 3) 3) 3)==255)
print("10 4x4x4x4 nested list (expect [0][0][0][0]=0, [3][3][3][3]=255): %v %v\n\n" at(at(at(at(d4 0) 0) 0) 0) at(at(at(at(d4 3) 3) 3) 3))
prev_ok=check_fail(:ok ok)

// --- test 11: attrlist containing lists containing attrlists ---
root=attrlist(
  :name "root"
  :children list())
root.children,attrlist(:name "child0" :val 10)
root.children,attrlist(:name "child1" :val 20)
root.children,attrlist(:name "child2" :val 30)
ok=ok&&(size(root.children)==3)
ok=ok&&(at(root.children 0).val==10)
ok=ok&&(at(root.children 2).name=="child2")
print("11 attrlist-list-attrlist nesting (expect 3 children, val=10, name=child2): %v %v %v\n\n" size(root.children) at(root.children 0).val at(root.children 2).name)
prev_ok=check_fail(:ok ok)

// =========================================================
// PART 4: Deep binary expressions
// =========================================================

// --- test 12: 4-deep addition expression ---
a=1; b=2; c=3; d=4; e=5; f=6; g=7; h=8
r=((a+b)+(c+d))+((e+f)+(g+h))
ok=ok&&(r==36)
print("12 4-deep addition (expect 36): %v\n\n" r)
prev_ok=check_fail(:ok ok)

// --- test 13: 4-deep mixed operators ---
r=(((10*2)+3)-1)*((4+1)*(2-1))
ok=ok&&(r==110)
print("13 4-deep mixed ops (expect 110): %v\n\n" r)
prev_ok=check_fail(:ok ok)

// --- test 14: 4-deep boolean expression ---
x=5
r=(((x>0)&&(x<10))&&((x!=3)&&(x!=7)))&&(x==5)
ok=ok&&(r==true)
print("14 4-deep boolean (expect true): %v\n\n" r)
prev_ok=check_fail(:ok ok)

// --- test 15: 4-deep attrlist expression building ---
al=(attrlist(:a 1)+attrlist(:b 2))+(attrlist(:c 3)+attrlist(:d 4))
ok=ok&&(size(al)==4)
ok=ok&&(al.a+al.b+al.c+al.d==10)
print("15 4-deep attrlist merge (expect size=4, sum=10): %v %v\n\n" size(al) (al.a+al.b+al.c+al.d))
prev_ok=check_fail(:ok ok)

// --- test 16: deeply nested if/cond ---
x=7
r=if(x>0 :then if(x>5 :then if(x>6 :then if(x==7 :then "seven" :else "not7") :else "le6") :else "le5") :else "neg")
ok=ok&&(r=="seven")
print("16 4-deep nested if (expect \"seven\"): %v\n\n" r)
prev_ok=check_fail(:ok ok)

// --- test 17: 4-deep cond ---
x=42
r=cond(x<0 "neg" cond(x==0 "zero" cond(x<10 "small" cond(x<100 "medium" "large"))))
ok=ok&&(r=="medium")
print("17 4-deep cond (expect \"medium\"): %v\n\n" r)
prev_ok=check_fail(:ok ok)

// =========================================================
// PART 5: Control flow building large structures
// =========================================================

// --- test 18: for building attrlist list, while consuming it ---
records=list()
for(i=0 i<100 i++
  records,attrlist(:id i :val i*i))
ok=ok&&(size(records)==100)
// consume with while + next via index
total=0
i=0
while(i<size(records) total=total+at(records i).val; i=i+1)
ok=ok&&(total==328350)  // sum of i^2 for i=0..99
print("18 for-build while-consume 100 records (expect size=100, sum_sq=328350): %v %v\n\n" size(records) total)
prev_ok=check_fail(:ok ok)

// --- test 19: func building and returning a large list ---
make_list=func(
  lst=list();
  cnt=0;
  for(i=0 i<n i++ lst,i);
  lst)
result=make_list(:n 200)
ok=ok&&(size(result)==200)
ok=ok&&(at(result 199)==199)
print("19 func returning large list (expect size=200, last=199): %v %v\n\n" size(result) at(result 199))
prev_ok=check_fail(:ok ok)

// --- test 20: func returning deep attrlist ---
make_node=func(attrlist(:id n :left n*2+1 :right n*2+2 :depth int(n>0)))
nodes=list()
for(i=0 i<127 i++ nodes,make_node(:n i))
ok=ok&&(size(nodes)==127)
ok=ok&&(at(nodes 0).id==0)
ok=ok&&(at(nodes 0).left==1)
ok=ok&&(at(nodes 62).right==126)
print("20 func building binary tree nodes (expect size=127, root.left=1, node62.right=126): %v %v %v\n\n" size(nodes) at(nodes 0).left at(nodes 62).right)
prev_ok=check_fail(:ok ok)

// =========================================================
// PART 6: Merge and remove at scale
// =========================================================

// --- test 21: merge 10 attrlists via + in a loop ---
merged=attrlist()
for(i=0 i<10 i++
  merged=merged+attrlist(:v i))
// note: repeated :v key -- last write wins per + semantics
ok=ok&&(size(merged)==1)
ok=ok&&(merged.v==9)
print("21 merge 10 attrlists with same key (expect size=1, v=9): %v %v\n\n" size(merged) merged.v)
prev_ok=check_fail(:ok ok)

// --- test 22: merge 10 attrlists with unique keys ---
parts=list()
for(i=0 i<10 i++ parts=parts,attrlist(:v i))
// build one big attrlist from 10 single-key ones
// use + sequentially; each has unique position
big=attrlist(:k0 0)
big=big+attrlist(:k1 1)
big=big+attrlist(:k2 2)
big=big+attrlist(:k3 3)
big=big+attrlist(:k4 4)
big=big+attrlist(:k5 5)
big=big+attrlist(:k6 6)
big=big+attrlist(:k7 7)
big=big+attrlist(:k8 8)
big=big+attrlist(:k9 9)
ok=ok&&(size(big)==10)
ok=ok&&(big.k0==0)
ok=ok&&(big.k9==9)
total=0
for(i=0 i<size(big) i++ total=total+attrval(at(big i)))
ok=ok&&(total==45)
print("22 merge 10 unique-key attrlists (expect size=10, sum=45): %v %v\n\n" size(big) total)
prev_ok=check_fail(:ok ok)

// --- test 23: remove half the keys from a large attrlist ---
al=attrlist(:k0 0 :k1 1 :k2 2 :k3 3 :k4 4 :k5 5 :k6 6 :k7 7 :k8 8 :k9 9)
mask=attrlist(:k1 0 :k3 0 :k5 0 :k7 0 :k9 0)
diff=al-mask
ok=ok&&(size(diff)==5)
ok=ok&&(diff.k0==0)
ok=ok&&(diff.k2==2)
ok=ok&&(diff.k4==4)
ok=ok&&(diff.k1==nil)
ok=ok&&(diff.k9==nil)
print("23 remove 5 of 10 keys (expect size=5, k0=0, k1=nil): %v %v %v\n\n" size(diff) diff.k0 diff.k1)
prev_ok=check_fail(:ok ok)

// =========================================================
// PART 7: Boundary conditions
// =========================================================

// --- test 24: empty list operations ---
e=list()
ok=ok&&(size(e)==0)
ok=ok&&(at(e 0)==empty)
print("24 empty list size and at(0)==empty (expect 0, true): %v %v\n\n" size(e) at(e 0)==empty)
prev_ok=check_fail(:ok ok)

// --- test 25: single-element list ---
s=list(42)
ok=ok&&(size(s)==1)
ok=ok&&(at(s 0)==42)
print("25 single-element list (expect size=1, at(0)=42): %v %v\n\n" size(s) at(s 0))
prev_ok=check_fail(:ok ok)

// --- test 26: list containing nil elements ---
nlst=1,nil,3,nil,5
ok=ok&&(size(nlst)==5)
ok=ok&&(at(nlst 1)==nil)
ok=ok&&(at(nlst 3)==nil)
ok=ok&&(at(nlst 4)==5)
print("26 list with nil elements (expect size=5, [1]=nil, [4]=5): %v %v %v\n\n" size(nlst) at(nlst 1) at(nlst 4))
prev_ok=check_fail(:ok ok)

// --- test 27: attrlist with nil value ---
al=attrlist(:x nil :y 2)
ok=ok&&(al.x==nil)
ok=ok&&(al.y==2)
print("27 attrlist with nil value (expect x=nil, y=2): %v %v\n\n" al.x al.y)
prev_ok=check_fail(:ok ok)

// --- test 28: list of 1000 elements boundary ---
big=list()
for(i=0 i<1000 i++ big=big,i)
ok=ok&&(size(big)==1000)
ok=ok&&(at(big 999)==999)
print("28 list of 1000 (expect size=1000, last=999): %v %v\n\n" size(big) at(big 999))
prev_ok=check_fail(:ok ok)

// --- test 29: deeply nested attrlist 4 levels ---
d=attrlist(:a attrlist(:b attrlist(:c attrlist(:d 42))))
ok=ok&&(d.a.b.c.d==42)
print("29 4-deep nested attrlist (expect d.a.b.c.d==42): %v\n\n" d.a.b.c.d)
prev_ok=check_fail(:ok ok)

// --- test 30: build, mutate, re-enumerate large list ---
lst=list()
for(i=0 i<256 i++ lst=lst,i)
// mutate every other element
for(i=0 i<256 i++
  if(i%2==0 :then at(lst i :set i*2)))
// verify
ok=ok&&(at(lst 0)==0)
ok=ok&&(at(lst 2)==4)
ok=ok&&(at(lst 254)==508)
ok=ok&&(at(lst 1)==1)   // odd unchanged
ok=ok&&(at(lst 255)==255)
print("30 mutate every-other in 256-list (expect [0]=0,[2]=4,[254]=508,[1]=1,[255]=255): %v %v %v %v %v\n\n" at(lst 0) at(lst 2) at(lst 254) at(lst 1) at(lst 255))
prev_ok=check_fail(:ok ok)

print("deeptest: %v\n" ok)
ok
