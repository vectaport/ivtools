// src/comterp_/tests/random.comt -- slot 12 random value stress tests
//
// coverage: slot 12 random stress
// funcs: split index substr join eq size print + global while for if
//        next each $$ $ ,, return func
//
// Tests that functions handle unexpected/random value classes gracefully —
// no crash, no unknown result, no silent wrong answer.
// Uses a random seed printed at the start so failures are reproducible:
// if a test fails, rerun with srand(seed) to reproduce.
//
// Slot 12 value kinds exercised:
//   absent    -- argument/keyword not supplied
//   zero      -- 0, 0.0
//   neg       -- -1
//   bool-t    -- true (1)
//   bool-f    -- false (0)
//   nil       -- nil or unset
//   wrong-type -- valid keyword with incompatible type
//   random    -- rand()-sampled int, float, string, bool, nil
//
// Run from inside comterp, comdraw, or drawserv:
//   run("src/comterp_/tests/random.comt")

run("testlib.comt")
ok=true
seed=int(date()*1000%1000000)
srand(seed)
print("random.comt seed: %v (daily -- see issue: add time() command)\n\n" seed)

// --- test 1: size() with zero-length string (zero boundary) ---
ok=ok&&(size("")==0)
print("1 size(\"\") zero boundary (expect 0): %v\n\n" size(""))
prev_ok=check_fail(:ok ok)

// --- test 2: size() with nil (nil boundary) ---
r2=size(nil)
ok=ok&&(r2==0||r2==nil)
print("2 size(nil) nil boundary (expect 0 or nil): %v\n\n" r2)
prev_ok=check_fail(:ok ok)

// --- test 3: index() with empty string (zero boundary) ---
ok=ok&&(index("" "x")==nil)
print("3 index(\"\",\"x\") empty input (expect nil): %v\n\n" index("" "x"))
prev_ok=check_fail(:ok ok)

// --- test 4: index() with empty search (zero boundary) ---
ok=ok&&(index("hello" "")==0||index("hello" "")==nil)
print("4 index(\"hello\",\"\") empty search (expect 0 or nil): %v\n\n" index("hello" ""))
prev_ok=check_fail(:ok ok)

// --- test 5: split() with empty string (zero boundary) ---
lst=split("")
ok=ok&&((size(lst)==0&&type(lst)==`ListType)||lst==nil)
print("5 split(\"\") empty (expect empty or nil): %v\n\n" lst)
prev_ok=check_fail(:ok ok)

// --- test 6: split() with single char (pos boundary) ---
lst=split("a")
ok=ok&&(size(lst)==1)
ok=ok&&(at(lst 0)=='a')
print("6 split(\"a\") single char (expect {'a'}): %v\n\n" lst)
prev_ok=check_fail(:ok ok)

// --- test 7: split() :tokstr with empty string ---
lst=split("" :tokstr)
ok=ok&&(lst==nil||size(lst)==0)
print("7 split(\"\") :tokstr empty (expect nil or empty): %v\n\n" lst)
prev_ok=check_fail(:ok ok)

// --- test 8: eq() bool-t vs bool-f (bool boundary) ---
ok=ok&&(eq(true false)==false)
ok=ok&&(eq(true true)==true)
ok=ok&&(eq(false false)==true)
print("8 eq() bool boundaries (expect false,true,true): %v,%v,%v\n\n" eq(true false) eq(true true) eq(false false))
prev_ok=check_fail(:ok ok)

// --- test 9: eq() nil vs nil (nil boundary) ---
r9=eq(nil nil)
ok=ok&&(r9==true&&type(r9)==`BooleanType)
print("9 eq(nil nil) (expect true, BooleanType): %v %v\n\n" r9 type(r9))
prev_ok=check_fail(:ok ok)

// --- test 10: eq() zero vs false (zero vs bool-f) ---
ok=ok&&(type(eq(0 false))==`BooleanType)
print("10 eq(0 false) (expect boolean result): %v\n\n" eq(0 false))
prev_ok=check_fail(:ok ok)

// --- test 11: global() with zero value (zero boundary) ---
global(gzero)=0
ok=ok&&(global(gzero)==0)
print("11 global()=0 zero boundary (expect 0): %v\n\n" global(gzero))
prev_ok=check_fail(:ok ok)

// --- test 12: global() with false (bool-f boundary) ---
global(gbool)=false
ok=ok&&(global(gbool)==false)
print("12 global()=false bool-f boundary (expect false): %v\n\n" global(gbool))
prev_ok=check_fail(:ok ok)

// --- test 13: global() with neg (neg boundary) ---
global(gneg)=-1
ok=ok&&(global(gneg)==-1)
print("13 global()=-1 neg boundary (expect -1): %v\n\n" global(gneg))
prev_ok=check_fail(:ok ok)

// --- test 14: while() with false condition (bool-f) ---
i=0
while(false (i=i+1))
print("14 while(false) zero or one iterations (actual i): %v\n\n" i)
// note: false as while condition behavior may vary -- not asserting exact count
prev_ok=check_fail(:ok ok)

// --- test 15: while() with 0 condition (zero boundary) ---
i=0
while(0 (i=i+1))
ok=ok&&(i==0)
print("15 while(0) zero boundary (expect i=0): %v\n\n" i)
prev_ok=check_fail(:ok ok)

// --- test 16: for() with zero iterations (zero boundary) ---
i=0
for(j=0 j<0 j++ i=i+1)
ok=ok&&(i==0)
print("16 for(0 iters) zero boundary (expect i=0): %v\n\n" i)
prev_ok=check_fail(:ok ok)

// --- test 17: next() on empty stream (zero boundary) ---
s=$$(1)
next(s)
v=next(s)
ok=ok&&(v==nil)
print("17 next() exhausted stream (expect nil): %v\n\n" v)
prev_ok=check_fail(:ok ok)

// --- test 18: random int stress on size() ---
r1=int(rand()*1000)
r2=int(rand()*1000)
r3=int(rand()*1000)
print("18 random ints for rand() sampling: %v %v %v\n\n" r1 r2 r3)
ok=ok&&(type(r1)==`IntType||type(r1)==`DfintType)
prev_ok=check_fail(:ok ok)

// --- test 19: random float stress ---
f1=rand()
f2=rand()
f3=rand()
ok=ok&&(f1>=0&&f1<=1)
ok=ok&&(f2>=0&&f2<=1)
print("19 rand() in [0,1] (expect true,true): %v,%v\n\n" (f1>=0&&f1<=1) (f2>=0&&f2<=1))
prev_ok=check_fail(:ok ok)

// --- test 20: size() with random-length string ---
n=int(rand()*10)+1
s=substr("abcdefghij" 1 :n n)
ok=ok&&(size(s)>=0)
print("20 size(random substr) (expect >=0): %v\n\n" size(s))
prev_ok=check_fail(:ok ok)

// --- test 21: if() with zero (zero as false boundary) ---
r=if(0 :then 99 :else 42)
ok=ok&&(r==42)
print("21 if(0) zero-as-false (expect 42): %v\n\n" r)
prev_ok=check_fail(:ok ok)

// --- test 22: if() with nil (nil as false boundary) ---
r=if(nil :then 99 :else 42)
ok=ok&&(r==42)
print("22 if(nil) nil-as-false (expect 42): %v\n\n" r)
prev_ok=check_fail(:ok ok)

// --- test 23: join() with empty list (zero boundary) ---
lst=split("")
s=join(lst)
ok=ok&&(s==""||s==nil)
print("23 join(empty) zero boundary (expect \"\" or nil): %v\n\n" s)
prev_ok=check_fail(:ok ok)

// --- test 24: substr() with zero-length match (zero boundary) ---
r=substr("hello" "" :nonil)
ok=ok&&(type(r)==`StringType)
print("24 substr(str \"\") zero-length (expect string): %v\n\n" r)
prev_ok=check_fail(:ok ok)

print("\nrandom: %v\n" ok)
ok
