// stream-literal.comt version 3
print("stream-literal.comt version 3\n")

// src/comterp_/tests/stream-literal.comt -- stream literal syntax tests
//
// coverage: 17 tests of stream literal feature
// funcs: postfix() errmsg() index() next() list() each() size() class()
// tests 1-8:   parser tests (postfix inspection)
// tests 9-14:  stream literal runtime behavior
// tests 15-17: stream-of-streams construction and zip behavior
//
// Run from inside comterp, comdraw, or drawserv:
//   run("src/comterp_/tests/stream-literal.comt")

// clear any prior error
errmsg(:clear)

run("./testlib.comt")
ok=true

// --- test 1: (42) is still a scalar -- no stream command in postfix ---
// BEFORE: passes  AFTER: passes  (single value, not a stream literal)
v=(42)
ok=ok&&(v==42)
p=postfix((42))
ok=ok&&(index(p "stream")==nil)
print("1 postfix((42)) -- scalar not stream (expect no 'stream' in postfix and v==42): %v %v\n" v p)
prev_ok=check_fail(:ok ok)

// --- test 2: (0 1) has stream command in postfix ---
// BEFORE: fails -- "Unexpected literal constant"
// AFTER:  passes -- stream[2|0|1]* in postfix
errmsg(:clear)
p=nil
p=postfix((0 1))
errmsg(:clear)
ok=ok&&(index(p "stream")!=nil)
print("2 postfix((0 1)) -- stream literal (expect 'stream' in postfix): %v\n" p)
prev_ok=check_fail(:ok ok)

// --- test 3: (0 1 2 3) has stream command with narg=4 ---
// BEFORE: fails
// AFTER:  passes -- stream[4|0|1]* in postfix
errmsg(:clear)
p=nil
p=postfix((0 1 2 3))
errmsg(:clear)
ok=ok&&(index(p "stream[4|0|1]")!=nil)
print("3 postfix((0 1 2 3)) -- stream[4|0|1] (expect stream[4|0|1] in postfix): %v\n" p)
prev_ok=check_fail(:ok ok)

// --- test 4: (42) postfix is just the literal ---
// BEFORE: passes  AFTER: passes
p=postfix((42))
ok=ok&&(p=="42")
print("4 postfix((42)) -- just literal (expect \"42\"): %v\n" p)
prev_ok=check_fail(:ok ok)

// --- test 5: (0 :flag 1) no error, stream literal narg=1 nkey=1 ---
// BEFORE: fails -- p=nil (error from run() prevents postfix from working)
// AFTER:  passes -- no error, stream[1|1|1]* in postfix
errmsg(:clear)
run("(0 :flag 1)" :str)
errmsg(:clear)
p=nil
p=postfix((0 :flag 1))
errmsg(:clear)
ok=ok&&(index(p "stream")!=nil)
print("5 postfix((0 :flag 1)) -- stream literal (expect 'stream' in postfix): %v\n" p)
prev_ok=check_fail(:ok ok)

// --- test 6: (0 1 :key 99) stream[3|1|1] in postfix ---
// BEFORE: fails -- p=nil
// AFTER:  passes -- stream[3|1|1]* in postfix
errmsg(:clear)
run("(0 1 :key 99)" :str)
errmsg(:clear)
p=nil
p=postfix((0 1 :key 99))
errmsg(:clear)
ok=ok&&(index(p "stream[3|1|1]")!=nil)
print("6 postfix((0 1 :key 99)) -- stream[3|1|1] (expect stream[3|1|1] in postfix): %v\n" p)
prev_ok=check_fail(:ok ok)

// --- test 7: (0 :key 1 2) still errors -- bare value after keyword ---
// BEFORE: passes  AFTER: passes  (always an error regardless of patch)
errmsg(:clear)
run("(0 :key 1 2)" :str)
e7=errmsg(:last)
ok=ok&&(e7!=nil)
print("7 (0 :key 1 2) -- error preserved (expect error): %v\n" e7)
prev_ok=check_fail(:ok ok)

// --- test 8: (:key val) still produces attrlist not stream ---
// BEFORE: passes  AFTER: passes  (keyword-first path unchanged)
errmsg(:last)
al=(:a 1 :b 2)
ok=ok&&(class(al)==`AttributeList)
p=postfix((:a 1 :b 2))
ok=ok&&(index(p "attrlist")!=nil)
ok=ok&&(index(p "stream")==nil)
print("8 (:a 1 :b 2) -- attrlist not stream (expect attrlist no stream in postfix): %v\n" p)
prev_ok=check_fail(:ok ok)

// =========================================================
// PART 2: Stream literal actual stream behavior
// (requires StreamLiteralNextFunc in strmfunc.c)
// =========================================================

// --- test 9: stream literal produces a working stream ---
// BEFORE strmfunc patch: next() returns nil (no StreamLiteralNextFunc)
// AFTER:  next() returns values lazily one at a time
s=(10 20 30)
v1=next(s); v2=next(s); v3=next(s); v4=next(s)
ok=ok&&(v1==10)
ok=ok&&(v2==20)
ok=ok&&(v3==30)
ok=ok&&(v4==nil)
print("9 next() on (10 20 30) (expect 10 20 30 nil): %v %v %v %v\n" v1 v2 v3 v4)
prev_ok=check_fail(:ok ok)

// --- test 10: stream literal is lazy -- rand evaluated fresh each next() ---
// BEFORE: nil
// AFTER:  three independently evaluated rand values
srand(42)
s=(rand rand rand)
r1=next(s)
r2=next(s)
r3=next(s)
ok=ok&&(r1!=empty())
ok=ok&&(r2!=empty())
ok=ok&&(r3!=empty())
print("10 (rand rand rand) lazy eval (expect 3 distinct rand values): %v %v %v\n" r1 r2 r3)
prev_ok=check_fail(:ok ok)

// --- test 11: nil in stream terminates early ---
// BEFORE: nil
// AFTER:  stream stops at nil, returns empty() on next call
s=(1 nil 3)
v1=next(s); v2=next(s)
ok=ok&&(v1==1)
ok=ok&&(v2==nil)
print("11 next() on (1 nil 3) -- nil terminates stream (expect 1 nil): %v %v\n" v1 v2)
prev_ok=check_fail(:ok ok)

// --- test 12: each() on stream literal returns count ---
// BEFORE: 0 or error
// AFTER:  4
ok=ok&&(each((10 20 30 40))==4)
print("12 each((10 20 30 40)) (expect 4): %v\n" each((10 20 30 40)))
prev_ok=check_fail(:ok ok)

// --- test 13: keyword element becomes singleton attrlist ---
// BEFORE fix: stream terminates after positionals, keyword element missing
// AFTER fix:  (0 :key 1) yields 0 then (:key 1) then nil
s=(0 :key 1)
v1=next(s); v2=next(s); v3=next(s)
ok=ok&&(v1==0)
ok=ok&&(class(v2)==`AttributeList)
ok=ok&&(v2.key==1)
ok=ok&&(v3==nil)
print("13 next() on (0 :key 1) -- keyword element as attrlist (expect 0 (:key 1) nil): %v %v %v\n" v1 v2 v3)
prev_ok=check_fail(:ok ok)

// --- test 14: stream literal and list duality ---
// (4 :b 3) as stream materializes to same list as {4,(:b 3)}
// BEFORE: stream literals didn't work
// AFTER:  list((4 :b 3)) == {4,(:b 3)}
l1=list((4 :b 3))
l2=list(4,((:b 3)))
ok=ok&&(size(l1)==2)
ok=ok&&(at(l1 0)==4)
ok=ok&&(class(at(l1 1))==`AttributeList)
ok=ok&&(at(l1 0)==at(l2 0))
ok=ok&&(class(at(l2 1))==`AttributeList)
print("14 list((4 :b 3)) -- list duality (expect {4,(:b 3)}): %v\n" l1)
prev_ok=check_fail(:ok ok)

// =========================================================
// PART 3: Stream-of-streams construction and zip behavior
// =========================================================

// --- test 15: nested stream literal syntax ((1 2 3)(4 5 6)) ---
// BEFORE fix: parse error -- "Unexpected left parenthesis"
// AFTER fix:  outer stream yields two independent inner StreamObjs lazily,
//             next() on each inner stream gives {1,2,3} and {4,5,6}
errmsg(:clear)
ss=nil
ss=((1 2 3)(4 5 6))
e15=errmsg(:last)
errmsg(:clear)
ok15=(e15==nil)
r0=next(ss); r1=next(ss); eot=next(ss)
ok15=ok15&&(class(r0)==`StreamObj)
ok15=ok15&&(class(r1)==`StreamObj)
ok15=ok15&&(eot==nil)
ok15=ok15&&(list(r0)==(1,2,3))
ok15=ok15&&(list(r1)==(4,5,6))
ok=ok&&ok15
print("15 ((1 2 3)(4 5 6)) -- nested stream literal (expect StreamObj StreamObj nil): %v %v %v\n" r0 r1 eot)
prev_ok=check_fail(:ok ok)

// --- test 16: $$(1,2,3),$$(4,5,6) -- comma overdriven by two streams zips them ---
// $$ binds tightly to next expr only; comma between two streams is overdriven
// and produces a zip stream of paired elements, NOT a stream-of-rows.
// This is the currently-working construction; result is a zip not nested streams.
// ACTUAL: list() gives {{1,4},{2,5},{3,6}}
ss2=$$(1,2,3),$$(4,5,6)
l16=list(ss2)
ok=ok&&(l16==((1,4),(2,5),(3,6)))
print("16 $$(1,2,3),$$(4,5,6) -- zip via overdriven comma (expect {{1,4},{2,5},{3,6}}): %v\n" l16)
prev_ok=check_fail(:ok ok)

// --- test 17: double zipper -- known unexpected behavior ---
// $$(($$(1,2,3),$$(4,5,6)),($$(11,12,13),$$(14,15,16)))
// EXPECTED if double zip were symmetric: {{1,4,11,14},{2,5,12,15},{3,6,13,16}}
// ACTUAL: {{1,4,{11,14}},{2,5,{12,15}},{3,6,{13,16}}}
// Second group arrives as StreamObj and is appended as nested element
// rather than being zipped peer-to-peer with the first group.
// Root cause unknown -- preserved as regression/investigation anchor.
ss3=$$(($$(1,2,3),$$(4,5,6)),($$(11,12,13),$$(14,15,16)))
l17=list(ss3)
ok17=(l17==((1,4,{11,14}),(2,5,{12,15}),(3,6,{13,16})))
ok=ok&&ok17
print("17 $$(($$(1,2,3),$$(4,5,6)),($$(11,12,13),$$(14,15,16))) -- double zipper (expect {{1,4,11,14},{2,5,12,15},{3,6,13,16}} actual {{1,4,{11,14}},...}): %v\n" l17)
prev_ok=check_fail(:ok ok)

print("stream-literal: %v\n" ok)
ok
