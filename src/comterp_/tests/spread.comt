// spread.comt -- the ~~ spread operator expands a stream (or list) into the
// positional (var-arg) slots of the enclosing command, so ONE command runs
// once over all the elements (batch), rather than $/list (elements in one list
// arg) or a bare stream (per-element overdrive replay).
//
// Probe: print() is an eager command that consumes its format left-to-right
// across its positional values in one pass, so a format with N specs and N
// values renders each -- revealing that ~~ delivered N separate positionals.
// (Only an EAGER enclosing command; post_eval commands like posteval read
// token-spans, not the operand stack, so ~~ does not reach them.)
//
// coverage: ~~ spread operator (stream/list -> var-args), one enclosing call
// funcs: spread stream print
// missing:
ok=1

// baseline -- three literal positionals fill three format specs
ok=ok&&(print("[%d %d %d]" 1 2 3 :str)=="[1 2 3]")
print("literal 1 2 3 -> [1 2 3] baseline (ok=%d)\n" ok)

// spread a LIST literal into three positionals: ~~(1,2,3) == 1 2 3
ok=ok&&(print("[%d %d %d]" ~~(1,2,3) :str)=="[1 2 3]")
print("~~(1,2,3) list spread -> [1 2 3] (ok=%d)\n" ok)

// spread a $$ STREAM into three positionals
ok=ok&&(print("[%d %d %d]" ~~$$(4,5,6) :str)=="[4 5 6]")
print("~~$$(4,5,6) stream spread -> [4 5 6] (ok=%d)\n" ok)

// a leading literal positional, then a spread tail -- order preserved
ok=ok&&(print("[%d %d %d %d]" 9 ~~(1,2,3) :str)=="[9 1 2 3]")
print("9 ~~(1,2,3) leading literal + spread -> [9 1 2 3] (ok=%d)\n" ok)

// scalar spreads to a single positional (~~ delegates to $$'s scalar->singleton)
ok=ok&&(print("[%d]" ~~(8) :str)=="[8]")
print("~~(8) scalar spread -> [8] (ok=%d)\n" ok)

print("spread: %v\n" ok)
ok
