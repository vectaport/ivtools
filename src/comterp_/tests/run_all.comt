// networking: remote() round-trip over a real socket to a `comterp server`
// child (launches/tears down its own servers; needs comterp on PATH)
if(run("./updown.comt")
  :then print("pass: updown\n")
  :else print("FAIL: updown\n");topok=false)
if(run("./spread.comt")
