// six petals, drawn in comterp.
// the script is the picture.
closedspline(160,160, 160,40, 220,55, 264,100, 160,160)
colors(3 10)  // Red
pattern(2) // Solid

closedspline(160,160, 264,100, 288,160, 264,220, 160,160)
colors(6 10)  // Green

closedspline(160,160, 264,220, 220,265, 160,280, 160,160)
colors(5 10)  // Yellow

closedspline(160,160, 160,280, 100,265, 56,220, 160,160)
colors(4 10)  // Orange

closedspline(160,160, 56,220, 32,160, 56,100, 160,160)
colors(7 10)  // Blue

closedspline(160,160, 56,100, 100,55, 160,40, 160,160)
colors(2 10)  // Brown

ellipse(160,160, 120,120)
colors(1 10)  // Black circle, around it
pattern(1)    // None
brush(5)      // Thick

// --- spin ---
// Rotating a multi-selection turns each graphic about its OWN center, so the
// petals would spin in place instead of orbiting.  Collapse the whole picture
// into one group first (group() -- #157) so rotate() pivots about the group's
// shared center (160,160).
select(:all)
group()

// spin the group a couple degrees per frame, paced by update(usec).
// rotate(degflt) rotates the current selection; the group stays selected.
frames = 720
f = 0
for(f=0 f<frames f++
  select(:all);
  rotate(2);
  update(20000))    // 20 ms / frame

select(:clear)